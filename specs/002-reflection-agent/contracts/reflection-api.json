{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReflectionEnvelope",
  "type": "object",
  "properties": {
    "trigger_type": {
      "type": "string",
      "enum": ["session_completion", "weekly_review", "recovery_completion"]
    },
    "prompt_text": {
      "type": "string"
    },
    "response_text": {
      "type": ["string", "null"]
    },
    "skipped": {
      "type": "boolean"
    }
  },
  "required": ["trigger_type", "prompt_text", "skipped"]
}
