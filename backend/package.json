{
  "name": "bloom-backend",
  "version": "1.0.0",
  "description": "Backend Coordinator for Bloom Coaching Core",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "test": "jest",
    "db:migrate": "tsc && node --env-file=.env dist/db/migrate.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^0.6.0",
    "eventsource": "^4.1.0",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "openai": "^6.45.0",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.9",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.5",
    "tsx": "^4.22.4",
    "typescript": "^5.5.2"
  }
}
